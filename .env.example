# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# JAMENDO: Client id for Jamendo API track search (Layer 2 provider fleet).
# Register at https://devportal.jamendo.com/
VITE_JAMENDO_CLIENT_ID="MY_JAMENDO_CLIENT_ID"

# Tier 3/4 extraction backend (default port 3001) — run: npm run dev:tier34
TIER34_PORT=3001

# Sandbox Indexer is built-in (yt-dlp + Archive.org). Optional external indexer + Real-Debrid:
PROWLARR_URL=
PROWLARR_API_KEY=
REALDEBRID_API_KEY=

# Tier 3/4 blob storage root (optional — default: tier34-server/storage/)
# TIER34_STORAGE_PATH=D:\Music\SovereignBlobs

# Folder watch import path on the tier34 host (optional)
# TIER34_WATCH_PATH=D:\Music

# OpenSubsonic read-only API (Symfonium/Feishin) — default user/password: sandbox/sandbox
# SUBSONIC_USER=sandbox
# SUBSONIC_PASSWORD=sandbox
# SUBSONIC_BASE_URL=http://192.168.1.10:3001
# SUBSONIC_API_ENABLED=true
TIER34_CORS_ORIGIN=http://localhost:3002
TIER34_DEFENSE_PROTOCOL=true
# Interminable Tide anti-scraper stream trap — chaff|jitter|both|off (see docs/interminable-tide.md)
TIER34_INTERMINABLE_TIDE=chaff
# Require X-Sandbox-Client on stream endpoints (stricter; Subsonic auth still bypasses)
# TIER34_DEFENSE_STRICT=false

# Aggressive client prefetch — max upstream size for GET /api/stream/full (MB)
# TIER34_STREAM_FULL_MAX_MB=150

# Overlay stack (Headscale + Tailscale sidecar) — see .env.overlay.example and docs/overlay-network.md
# HEADSCALE_HTTP_PORT=8080
# HEADSCALE_LOGIN_SERVER=http://headscale:8080
# TAILSCALE_AUTHKEY=
# TAILSCALE_HOSTNAME=sandbox-tier34

# DLNA/UPnP MediaServer — TVs browse locker without the app (see docs/dlna-mediaserver.md)
# DLNA_MEDIASERVER=1
# DLNA_BASE_URL=http://192.168.1.42:3001
# DLNA_FRIENDLY_NAME=Sovereign Music Locker

# Sandbox Cast custom receiver (optional — TV visualizer on Cast receivers)
# Register at https://console.cast.google.com/ with receiver URL: https://your-host/cast-receiver.html
# Without this, audio casting still works via the default media receiver.
VITE_CAST_RECEIVER_APP_ID=

# yt-dlp binary for Tier 3 proxy resolve (full streams). Install: pip install yt-dlp
# Auto-fallback tries: yt-dlp, python -m yt_dlp, python3 -m yt_dlp
# Windows example: YTDLP_PATH=python -m yt_dlp
YTDLP_PATH=

# Spotify OAuth (optional — demo OAuth works without these)
SPOTIFY_CLIENT_ID=""
SPOTIFY_CLIENT_SECRET=""
SPOTIFY_REDIRECT_URI="http://localhost:3001/api/oauth/spotify/callback"
OAUTH_REDIRECT_URI="http://localhost:3001/api/oauth/spotify/callback"
