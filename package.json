{
  "name": "sovereign-music-console",
  "private": true,
  "version": "1.0.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "dev:tier34": "kill-port 3001 && tsx tier34-server/index.ts",
    "dev:tier34:restart": "kill-port 3001 && tsx tier34-server/index.ts",
    "test": "vitest run",
    "dev:all": "concurrently -n ui,t34 -c cyan,magenta \"npm run dev\" \"npm run dev:tier34\"",
    "check:platform": "node scripts/check-platform.mjs",
    "pull:device-download-errors": "node scripts/pull-device-download-errors.mjs",
    "prebuild:client": "npm run lint",
    "build:client": "npm run check:platform && vite build",
    "build:tier34": "node scripts/build-tier34.mjs",
    "build": "npm run build:client && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "build:web": "npm run build",
    "start": "node scripts/start-prod.mjs",
    "start:tier34": "tsx tier34-server/index.ts",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "node scripts/check-platform.mjs tauri && npm run build:client && node scripts/tauri-build.mjs",
    "tauri:icon": "tauri icon public/icon-desktop.svg",
    "build:desktop": "npm run tauri:build",
    "build:tauri": "npm run prebuild:desktop:assets && npm run tauri:build",
    "build:mobile": "npm run build:client && cap sync",
    "build:android": "node scripts/check-platform.mjs android && node scripts/vite-android-build.mjs && cap sync android && node scripts/cleanup-android-splash.mjs",
    "build:android:apk": "npm run build:android && node scripts/android-assemble-debug.mjs",
    "e2e:android:playback": "pwsh -File scripts/android-minimal-play-e2e.ps1",
    "e2e:phone:gate": "pwsh -File scripts/phone-playback-gate.ps1",
    "build:android:release": "npm run build:android && node scripts/android-assemble-release.mjs",
    "android:ci:keystore": "node scripts/android-ci-keystore.mjs",
    "android:package:release": "node scripts/android-package-release-apks.mjs",
    "fdroid:prebuild": "node scripts/fdroid-prebuild.mjs",
    "fdroid:assemble": "node scripts/fdroid-assemble-release.mjs",
    "fdroid:local": "npm run fdroid:prebuild && npm run fdroid:assemble",
    "beets:watch-sync": "node scripts/beets-watch-sync.mjs",
    "build:locales": "node scripts/build-all-locales.mjs",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "prebuild:desktop:assets": "node scripts/generate-tauri-icons.mjs && node scripts/run-generate-nsis-assets.mjs && node scripts/fetch-portable-node.mjs",
    "prebuild:desktop": "npm run prebuild:desktop:assets"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/local-notifications": "^8.2.0",
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@vitejs/plugin-react": "^5.0.4",
    "chokidar": "^4.0.3",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "ip": "^2.0.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "music-metadata": "^11.0.2",
    "node-ssdp": "^1.0.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3",
    "ws": "^8.18.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/ws": "^8.5.14",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "esbuild": "^0.25.0",
    "kill-port": "^2.0.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^3.2.4",
    "workbox-window": "^7.4.1"
  }
}
