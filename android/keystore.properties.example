# Copy to android/keystore.properties and fill in real values.
# Do NOT commit keystore.properties or *.keystore / *.jks files.
#
# F-Droid: NOT required for F-Droid submission. F-Droid builds from source and
# signs APKs with the F-Droid archive key. Optional here for local release APK
# sideload testing or App Signing by Maintainer (reproducible + your signature).
#
# Generate a release keystore (run once, store backup safely):
#   keytool -genkeypair -v -keystore release.keystore -alias sovereign-release \
#     -keyalg RSA -keysize 2048 -validity 10000 \
#     -storepass YOUR_STORE_PASSWORD -keypass YOUR_KEY_PASSWORD \
#     -dname "CN=Your Name, OU=Dev, O=Sovereign Music Console, L=City, ST=State, C=US"
#
# Place release.keystore in android/ (or set storeFile to an absolute path).
#
# GitHub Actions (signed release on tag v*): set repository secrets — see docs/android-release.md
#   ANDROID_KEYSTORE_BASE64, ANDROID_KEYSTORE_PASSWORD, ANDROID_KEY_ALIAS, ANDROID_KEY_PASSWORD

storeFile=release.keystore
storePassword=YOUR_STORE_PASSWORD
keyAlias=sovereign-release
keyPassword=YOUR_KEY_PASSWORD
