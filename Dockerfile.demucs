FROM python:3.11-slim-bookworm

RUN apt-get update && apt-get install -y --no-install-recommends ffmpeg \
  && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir demucs fastapi uvicorn[standard]

WORKDIR /app
COPY docker/demucs-api.py ./demucs-api.py

ENV TIER34_STORAGE_PATH=/data/storage
EXPOSE 8765

CMD ["uvicorn", "demucs-api:app", "--host", "0.0.0.0", "--port", "8765"]
