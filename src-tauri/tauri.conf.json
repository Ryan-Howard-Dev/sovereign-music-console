{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sandbox Music",
  "mainBinaryName": "Sandbox Music",
  "version": "1.0.0",
  "identifier": "rd.sheepskin.sandboxmusic",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3002",
    "beforeBuildCommand": "npm run build:client && npm run build:tier34",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Sandbox Music",
        "width": 1280,
        "height": 720,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "backgroundColor": "#07080c"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "resources": [
      "../dist/",
      "resources/node/"
    ],
    "targets": [
      "msi",
      "nsis",
      "deb",
      "appimage"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Music",
    "shortDescription": "Sandbox Music — self-hosted music console",
    "longDescription": "Sandbox Music — offline-first music locker, catalog discovery, and DJ console shell.",
    "copyright": "Copyright © 2026 Sandbox Music Contributors",
    "linux": {
      "deb": {
        "depends": []
      }
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "nsis": {
        "template": "nsis/installer-template.nsi",
        "installMode": "currentUser",
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "headerImage": "nsis/header.bmp",
        "sidebarImage": "nsis/sidebar.bmp",
        "uninstallerHeaderImage": "nsis/header-uninstall.bmp",
        "languages": [
          "English"
        ],
        "customLanguageFiles": {
          "English": "nsis/English.nsh"
        },
        "installerHooks": "nsis/installer-hooks.nsh",
        "startMenuFolder": "Sandbox Music"
      }
    }
  }
}
